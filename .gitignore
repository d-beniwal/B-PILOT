__pycache__/
*.pyc
.DS_Store

# Per-installation runtime override (regenerated on first Configuration save;
# should not carry machine-specific state between checkouts).
gui_config.json

# Per-workstation live settings, bootstrapped from each profile's committed
# default_config.json on first use — should not carry machine-specific state
# between checkouts.
profiles/*/active_config.json

# AutoPILOT is a separate, independently-versioned git repo nested here (same
# convention as B-PILOT itself being a nested repo inside the non-git
# mpe_bluesky tree). B-PILOT must never depend on or track it.
AutoPILOT/

# Local presentation/reference documents (overview + AutoPILOT architecture
# write-ups and their PDF renders) — working notes, not part of the repo.
documents/
